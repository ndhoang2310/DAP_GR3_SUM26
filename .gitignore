# ============================================================
# Eye Blink Detection - .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# --- Virtual Environment ---
venv/
env/
.venv/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Data & Dataset (too large for git) ---
data/
dataset/
dataset_master/

# --- Trained Models (large binary files) ---
models/*.pkl
models/*.dat
models/*.png

processed_image/*.npy
models/*.keras
models/*.h5 

# --- Logs & temp ---
*.log
*.tmp

# --- Jupyter ---
.ipynb_checkpoints/
/dataset
/dataset_master
