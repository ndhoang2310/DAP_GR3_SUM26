# ============================================================
# Eye Blink Detection - .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# --- Virtual Environment ---
venv/
env/
.venv/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Data & Dataset (too large for git) ---
data/*
!data/**/*.dvc
!data/**/.gitignore
!data/.gitignore
dataset/
dataset_master/
# --- Trained Models (large binary files) ---
models/*.pkl
models/*.dat
models/*.png

# --- Logs & temp ---
*.log
*.tmp

# --- Jupyter ---
.ipynb_checkpoints/
/dataset
